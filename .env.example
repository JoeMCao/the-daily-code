# PostgreSQL connection string used by Prisma.
# Local example (Docker, Postgres.app, or native install):
#   DATABASE_URL="postgresql://postgres:postgres@localhost:5432/daily_code?schema=public"
# Vercel + Neon/Supabase/etc. will provide one for you.
DATABASE_URL="postgresql://user:password@localhost:5432/daily_code?schema=public"
